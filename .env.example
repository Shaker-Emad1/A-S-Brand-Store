# Database
DATABASE_URL=postgres://postgres:YourStrongPassw0rd@localhost:5432/asbrandstore
DB_PASSWORD=YourStrongPassw0rd

# Domain
DOMAIN=yourdomain.com

# JWT
JWT_SECRET=YourSuperSecretKey_AtLeast32CharactersLong!

# Administrator Bootstrap (required on first deploy)
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=ChangeThisImmediately123!

# Frontend build / local development
VITE_API_BASE_URL=/api
VITE_API_PROXY_TARGET=http://localhost:5262

# Cloudinary (REQUIRED - only image storage provider)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# WhatsApp (optional - order notifications)
WHATSAPP_PROVIDER=Mock
WHATSAPP_API_URL=
WHATSAPP_TOKEN=
WHATSAPP_INSTANCE_ID=

# Google Sheets (optional - order logging)
GOOGLE_SHEETS_CREDENTIALS=
GOOGLE_SHEETS_WEBHOOK_URL=
GOOGLE_SHEETS_SPREADSHEET_ID=
