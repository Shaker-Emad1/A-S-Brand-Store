<Window x:Class="ASBrandStoreLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ASBrandStoreLauncher"
        mc:Ignorable="d"
        Title="ASBrandStore E-Commerce Launcher | مشغّل المشروع" Height="650" Width="900"
        Background="#121212" Foreground="#FFFFFF" FontFamily="Segoe UI, Tahoma"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResizeWithGrip"
        Closing="Window_Closing">

    <Window.Resources>
        <!-- Modern Button Style -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#252526"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="6"/>
                </Style>
            </Style.Resources>
        </Style>

        <!-- Status Card Border Style -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="BorderBrush" Value="#2D2D30"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="15"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <!-- Header Section -->
            <RowDefinition Height="Auto"/>
            <!-- Status Cards -->
            <RowDefinition Height="Auto"/>
            <!-- Controls Section -->
            <RowDefinition Height="Auto"/>
            <!-- Tabbed Logs -->
            <RowDefinition Height="*"/>
            <!-- Footer -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="لوحة تحكم مشروع ASBrandStore" FontSize="24" FontWeight="Bold" Foreground="#FFD700"/>
                <TextBlock Text="شغّل وتابع أداء السيرفرات والواجهات بضغطة زر واحدة" FontSize="13" Foreground="#8A8A8A" Margin="0,3,0,0"/>
            </StackPanel>
            <TextBlock Grid.Column="1" Text="💎 Premium Edition" VerticalAlignment="Center" FontSize="12" Foreground="#8A8A8A" Background="#2A2A2A" Padding="8,4" ClipToBounds="True">
                <TextBlock.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="10"/>
                    </Style>
                </TextBlock.Resources>
            </TextBlock>
        </Grid>

        <!-- Status Cards -->
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Backend Status Card -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="واجهة البرمجة (Backend API)" FontSize="15" FontWeight="SemiBold" Foreground="#E0E0E0"/>
                        <TextBlock x:Name="BackendUrlText" Text="Configured at runtime" FontSize="12" Foreground="#8A8A8A" Margin="0,3,0,10"/>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="BackendStatusIndicator" Width="10" Height="10" Fill="#FF3B30" VerticalAlignment="Center"/>
                            <TextBlock x:Name="BackendStatusText" Text="متوقف" FontSize="13" FontWeight="Bold" Foreground="#FF3B30" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                    <Button Grid.Column="1" Content="⚙️ Swagger" Background="#6A1B9A" VerticalAlignment="Center" Click="OpenSwagger_Click"/>
                </Grid>
            </Border>

            <!-- Frontend Status Card -->
            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="واجهة المستخدم (Frontend UI)" FontSize="15" FontWeight="SemiBold" Foreground="#E0E0E0"/>
                        <TextBlock x:Name="FrontendUrlText" Text="Configured at runtime" FontSize="12" Foreground="#8A8A8A" Margin="0,3,0,10"/>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="FrontendStatusIndicator" Width="10" Height="10" Fill="#FF3B30" VerticalAlignment="Center"/>
                            <TextBlock x:Name="FrontendStatusText" Text="متوقف" FontSize="13" FontWeight="Bold" Foreground="#FF3B30" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                    <Button Grid.Column="1" Content="🌐 فتح الموقع" Background="#008080" VerticalAlignment="Center" Click="OpenFrontend_Click"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Controls Section -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
            <Button x:Name="StartBtn" Content="▶ تشغيل المشروع بالكامل" Background="#2E7D32" FontSize="16" Width="250" Height="45" Margin="0,0,15,0" Click="StartBtn_Click"/>
            <Button x:Name="StopBtn" Content="⏹ إيقاف تشغيل المشروع" Background="#C62828" FontSize="16" Width="250" Height="45" IsEnabled="False" Click="StopBtn_Click"/>
        </StackPanel>

        <!-- Tabbed Logs -->
        <TabControl Grid.Row="3" Background="#1E1E1E" BorderBrush="#2D2D30">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="HeaderTemplate">
                        <Setter.Value>
                            <DataTemplate>
                                <ContentPresenter Content="{TemplateBinding Content}" Margin="10,5"/>
                            </DataTemplate>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Background" Value="#2D2D30"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Style>
            </TabControl.Resources>

            <TabItem Header="سجلات الباك إند (Backend Logs)">
                <TextBox x:Name="BackendLogBox" Background="#141414" Foreground="#A9B7C6" BorderThickness="0" FontFamily="Consolas, Courier New" FontSize="12" IsReadOnly="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" TextWrapping="Wrap"/>
            </TabItem>
            <TabItem Header="سجلات الفرونت إند (Frontend Logs)">
                <TextBox x:Name="FrontendLogBox" Background="#141414" Foreground="#A9B7C6" BorderThickness="0" FontFamily="Consolas, Courier New" FontSize="12" IsReadOnly="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" TextWrapping="Wrap"/>
            </TabItem>
        </TabControl>

        <!-- Footer -->
        <StatusBar Grid.Row="4" Background="Transparent" Foreground="#8A8A8A" FontSize="11" Margin="0,10,0,0">
            <StatusBarItem Content="تم التطوير بواسطة Antigravity AI 💎"/>
            <Separator Background="#2D2D30"/>
            <StatusBarItem x:Name="StatusInfoText" Content="جاهز للتشغيل"/>
        </StatusBar>
    </Grid>
</Window>
